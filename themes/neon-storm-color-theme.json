  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4A5F4A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Method Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "parameter.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "TypeScript: Constant Objects",
      "scope": [
        "variable.other.constant.object.ts",
        "variable.other.constant.object.js"
      ],
      "settings": {
        "foreground": "#4FC1FF"
      }
    },
    {
      "name": "Variables, Properties",
      "scope": [
        "variable",
        "variable.other",
        "variable.language",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Colors (Constants)",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e27e90",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "String Interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "Functions, Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "keyword.other.special-method",
        "meta.method-call",
        "meta.method.declaration"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Classes, Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace",
        "entity.other.attribute",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "Entity Types (Interfaces, Generics)",
      "scope": [
        "support.type.primitive",
        "entity.name.type.interface",
        "entity.name.type.type-parameter",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#73DACA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Classes and IDs",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id",
        "source.css entity.name.tag"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "Attributes, Decorators",
      "scope": [
        "entity.name.tag.yaml",
        "meta.decorator",
        "meta.decorator.python",
        "meta.decorator.ts",
        "meta.decorator.js",
        "punctuation.decorator",
        "storage.type.annotation",
        "storage.type.annotation.java",
        "storage.type.annotation.cs"
      ],
      "settings": {
        "foreground": "#9ECE6A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "C# Attributes",
      "scope": [
        "meta.attribute.cs",
        "entity.name.type.attribute.cs",
        "punctuation.section.attribute.begin.cs",
        "punctuation.section.attribute.end.cs",
        "meta.attribute.cs entity.name.type",
        "storage.type.cs.attributes"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "TypeScript Decorators",
      "scope": [
        "meta.decorator.ts entity.name.function.ts",
        "meta.decorator.js entity.name.function.js",
        "punctuation.decorator.ts",
        "punctuation.decorator.js"
      ],
      "settings": {
        "foreground": "#DCDCAA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML: Tags",
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.structure.any.html",
        "entity.name.tag.block.any.html",
        "entity.name.tag.inline.any.html",
        "entity.name.tag.script.html"
      ],
      "settings": {
        "foreground": "#3a95df"
      }
